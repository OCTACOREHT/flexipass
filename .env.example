# Core (required)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional explicit server URL override (if different from NEXT_PUBLIC_SUPABASE_URL)
SUPABASE_URL=

# Site URLs
NEXT_PUBLIC_SITE_URL=
SITE_URL=
APP_URL=
NEXT_PUBLIC_BASE_URL=

# MonCash
MONCASH_MODE=sandbox
MONCASH_CLIENT_ID=
MONCASH_CLIENT_SECRET=

# Email (SMTP)
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_FROM=
EMAIL_LOGO_URL=

# Resend (optional alternative provider for confirm endpoint)
RESEND_API_KEY=

# Social links (optional)
NEXT_PUBLIC_INSTAGRAM_URL=
NEXT_PUBLIC_FACEBOOK_URL=
NEXT_PUBLIC_LINKEDIN_URL=
NEXT_PUBLIC_TIKTOK_URL=
INSTAGRAM_URL=
FACEBOOK_URL=
LINKEDIN_URL=
TIKTOK_URL=

# Storage upload path (optional)
UPLOAD_STORAGE_PATH=product-images
